# Copy to .env.local and fill in only what you use.
# The template runs with NO keys by default (mock engine).
#
# Security note: variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# Keep real API keys un-prefixed and call providers from a route handler
# (app/api/run/route.ts) so keys stay server-side.

# OpenAI (alternative LLM backend: set CharacterLlmConfig.backend = "openai")
OPENAI_API_KEY=
OPENAI_API_KEY_GAME_MASTER=
# OPENAI_API_KEY_RESIDENT_VAMPIRE_GIRL=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Hugging Face Inference
HF_TOKEN=

# Gemini (default character + game-master LLM backend)
GEMINI_API_KEY=
GEMINI_API_KEY_GAME_MASTER=
# Optional per-character keys (example for Luna)
# GEMINI_API_KEY_RESIDENT_VAMPIRE_GIRL=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Local Chroma server
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Local model endpoint (e.g. Ollama)
LOCAL_MODEL_URL=http://localhost:11434

# Your own API
CUSTOM_API_URL=
CUSTOM_API_KEY=
